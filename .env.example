# ── AEO Pilot environment ─────────────────────────────────────────────
# Copy to .env. Everything has a sane default so the stack runs as-is.

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_USER=aeo
POSTGRES_PASSWORD=aeo
POSTGRES_DB=aeo
# Used by the backend container (host = docker-compose service name "db")
DATABASE_URL=postgresql+psycopg://aeo:aeo@db:5432/aeo

# ── Redis / Celery ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM provider (all optional — the slice runs without any key) ───────
# Provider abstraction default. One of: openai | anthropic | gemini
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Embeddings (pgvector). Optional in MVP.
EMBEDDING_MODEL=text-embedding-3-small

# ── Payments (Razorpay) ───────────────────────────────────────────────
# Backend only (put real values in backend/.env — gitignored). When unset,
# billing is disabled and plan CTAs stay as plain links. Get test keys from
# Razorpay Dashboard → Settings → API Keys (rzp_test_...).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── App ───────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-prod
# Max pages the crawler will fetch per scan (keep modest for politeness)
CRAWL_MAX_PAGES=15
CRAWL_TIMEOUT_SECONDS=10

# ── Frontend ──────────────────────────────────────────────────────────
# Browser-facing URL of the backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Supabase (auth + database) ────────────────────────────────────────
# Frontend: put these in frontend/.env.local (publishable key is browser-safe).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# If unset, the app runs OPEN (no auth gate). When set, /app + /scans require login.

# Backend → Supabase Postgres (optional). Requires the DB PASSWORD (not the
# publishable key) from Supabase → Project Settings → Database. Then point the
# backend at it instead of the local SQLite/Compose Postgres:
# DATABASE_URL=postgresql+psycopg://postgres:[DB_PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres
# Optional: service-role key for server-side admin ops (NEVER expose to browser):
# SUPABASE_SERVICE_ROLE_KEY=
