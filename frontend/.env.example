# ── Frontend env (Vercel) ─────────────────────────────────────────────
# Copy to .env.local for local dev. In Vercel, set these in
# Project → Settings → Environment Variables (Production + Preview).

# Public URL of the deployed backend API (FastAPI on Render/Railway/etc.)
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com

# Canonical site URL — drives sitemap.xml, robots.txt, canonical tags & schema.
# Use your real domain in production (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://aeo-pilot.vercel.app

# Supabase (publishable key is browser-safe)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Optional: Google Search Console HTML-tag verification token
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
